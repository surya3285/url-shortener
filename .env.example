# Copy to .env and adjust as needed. docker-compose reads these automatically.

# Port the app is served on (host side).
APP_PORT=8080

# Public base URL used to build returned short links. Must match how you
# reach the frontend in the browser.
BASE_URL=http://localhost:8080

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortener

# Flask
SECRET_KEY=change-me-in-production

# Length of generated short codes.
CODE_LENGTH=6

# Rate limit on the shorten endpoint (flask-limiter syntax).
SHORTEN_RATE_LIMIT=10 per minute
